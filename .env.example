# 北京房产监控系统 - 环境变量配置
# 复制此文件为 .env 并填写实际值

# ============================================
# Telegram Bot 配置（必需）
# ============================================

# Bot Token，从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 通知频道 ID（用于推送房源通知）
# 获取方式：创建频道，添加 Bot 为管理员，转发频道消息给 @userinfobot
TELEGRAM_CHANNEL_ID=-1001234567890

# 管理员私聊 ID（用于系统通知）
# 获取方式：给 @userinfobot 发送消息
TELEGRAM_ADMIN_ID=123456789

# ============================================
# Web 服务配置
# ============================================

# Web 登录用户名
WEB_USERNAME=admin

# Web 登录密码
WEB_PASSWORD=your_secure_password

# Web 服务端口（默认8080）
PORT=8080

# ============================================
# 系统配置（可选）
# ============================================

# 时区
TZ=Asia/Shanghai

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# ============================================
# 数据库配置（可选，默认使用 SQLite）
# ============================================

# 数据库路径（相对于项目根目录）
DATABASE_PATH=data/houses.db
